    <string name="about_ai_content">This application is built through human-AI collaboration. It was architected and implemented with the assistance of Google\'s Gemini AI.</string>
    <string name="about_ai_title">Built with AI</string>
    <string name="about_concept_content">Our philosophy is \'Quality First\'. We focus on dividend stocks with solid fundamentals, monitored through indicators like RSI and MACD to find high-probability zones.</string>
    <string name="about_concept_title">The Concept</string>
    <string name="about_copyright">© 2024 TradingMate Project</string>
    <string name="about_creator_content">Developed by Thawee P., a software engineer and trading enthusiast passionate about building tools for financial empowerement.</string>
    <string name="about_creator_title">The Creator</string>
    <string name="about_idea_content">TradingMate was born from the need for a disciplined, emotionless approach to stock trading. It aims to replace guesswork with data-driven signals.</string>
    <string name="about_idea_title">The Idea</string>
    <string name="about_tagline">Happy Trading! 🚀</string>
