abel_app_tagline">Your personal premium trading companion.</string><string name="label_copyright">© 2024 apincer mobile</string><string name="label_rr_calculator">Risk/Reward Calculator</string><string formatted="false" name="label_suggested_strategy">Suggested: 10% Target / 5% Stop (2.0 R:R)</string><string name="label_current_holdings_count">Current holdings: %1$d shares</string><string name="label_sell_note">Lessons Learned / Note</string><string formatted="false" name="hint_sell_note">e.g. Sold too early, RSI was 80</string><string name="label_sell_price">Sell Price</string><string name="label_quantity_to_sell">Quantity to Sell</string><string name="label_current_balance">Current: ฿%1$s</string><string name="label_amount_thb">Amount (THB)</string><string name="label_search_results">Search Results</string><string name="label_search_stock">Search Stock Symbol</string><string name="label_partial_data_warning">Partial Data: Some fundamental metrics could not be fetched.</string><string name="label_focus_tracker_info">We\'ll track movement from ฿%1$s and alert you on the Home screen when the price hits your target.</string><string name="label_rsi_meaning">Relative Strength Index. &lt; 30 is Cheap, > 70 is Expensive.</string><string name="label_sma_meaning">Trend lines. Price above SMA indicates a strong uptrend.</string><string name="label_bb_meaning">Volatility tube. Price often bounces between these bands.</string><string name="label_premium_financials">Premium Financials</string><string name="label_high_dividend_alert">High Dividend Yield Alert!</string><string name="label_view_quote">View Official Quote ↗</string><string name="label_rsi_zone_desc">Targets based on RSI reversal levels (35 Buy / 65 Sell).</string><string name="label_start_price">Start Price</string><string name="label_roe">ROE (%)</string><string name="label_net_profit">Net Profit</string><string name="label_net_margin">Net Margin (%)</string><string name="label_3y_growth">3Y Growth (%)</string><string name="label_eps">EPS</string><string name="label_de_ratio">D/E Ratio</string><string name="label_dividend_yield">Dividend Yield (%)</string><string name="label_last_xd">Last XD Date</string><string name="label_yoc">My Yield on Cost</string><string name="label_pe_ratio">P/E Ratio</string><string name="label_pbv_ratio">P/BV Ratio</string><string name="label_book_value">Book Value (P/BV=1.0)</string><string name="label_rsi_zones_title">RSI Zones</string><string name="label_price_return_history_title">Price Return History</string><string name="label_volume_surge">VOLUME SURGE</string><string name="label_total_symbols">Total Symbols</string><string name="label_to_sell">Sale Alert</string><string name="label_to_buy">Buy Alert</string><string name="label_attentions">Attentions</string><string name="label_active_holdings_count">%1$d Active Holdings</string><string name="label_not_set">Not Set</string><string name="label_target_monthly_dividend">Target Monthly Dividend</string><string name="label_alert_threshold_percent">Price Alert Threshold</string><string name="label_required_capital">Required Total Capital</string><string name="label_monthly_saving_needed">Suggested Monthly Saving</string><string name="label_est_avg_yield">Est. Portfolio Yield (5%)</string><string name="label_current_monthly_dividend">Current Monthly Dividend</string><string name="label_remaining_capital">Remaining Capital Needed</string><string name="label_goal_progress">Goal Progress</string><string name="label_plan_summary">To earn ฿%1$s/month, you need a portfolio of ฿%2$s.</string><string name="label_suggested_invest">Suggested Investment</string><string name="title_adjust_cash">Adjust Cash Balance</string><string name="title_record_purchase">Record Purchase</string><string name="title_edit_holding">Edit Holding</string><string name="title_sell_stock">Sell %1$s</string><string name="title_clear_history">Clear History</string><string name="title_clear_watchlist">Clear Watchlist</string><string name="title_import_set">Import SET Collection</string><string name="title_add_stock">Add Stock</string><string name="title_focus_on">Focus on %1$s</string><string name="action_add_funds">Add Funds</string><string name="action_set_balance">Set Balance</string><string name="action_cancel">Cancel</string><string name="action_add_to_portfolio">Add to Portfolio</string><string name="action_update">Update</string><string name="action_set_suggested">Set Suggested</string><string name="action_confirm_sell">Confirm Sell</string><string name="action_delete_all">Delete All</string><string name="action_clear_watchlist">Clear Watchlist</string><string name="action_clear_history">Clear History</string><string name="action_close">Close</string><string name="action_add_manually">Add Manually</string><string name="action_confirm_focus">Confirm Focus</string><string name="action_backup_data">Backup Data</string><string name="action_restore_data">Restore Data</string><string name="action_ready_to_trade">I\'m ready to trade</string><string name="desc_refresh">Refresh</string><string name="desc_buy_stock">Buy Stock</string><string name="desc_import_set">Import SET</string><string name="desc_add_stock">Add Stock</string><string name="desc_clear_history">Clear History</string><string name="desc_back">Back</string><string name="desc_focus">Focus</string><string name="confirm_clear_history">Are you sure you want to delete all trade history? This action cannot be undone.</string><string name="confirm_clear_watchlist">Are you sure you want to clear your watchlist? Portfolio stocks and focused holdings will be preserved.</string><string name="edu_workflow_title">Master the Workflow</string><string name="edu_workflow_subtitle">Disciplined steps for consistent profit.</string><string name="edu_step1_title">1. Discovery (Quality First)</string><string formatted="false" name="edu_step1_content">Don\'t gamble on random stocks. Use the \'+\' button to import curated collections or use the AI Advisor to find stocks that have already passed our strict 5-Layer filter.</string><string name="edu_risk_mgmt_title">The Art of the \'Cut Loss\'</string><string formatted="false" name="edu_risk_mgmt_content">The most important rule in trading is preserving your capital. \n\n• Why: Small losses are easy to recover. A -50% loss requires a +100% gain just to break even.\n• When: If a stock drops -5% from your cost, the app will trigger a SELL signal. This is your cue to exit and protect your remaining cash.</string><string name="edu_yoc_title">Fundamental Guardrails</string><string formatted="false" name="edu_yoc_content">We evaluate the \'DNA\' of every company before suggesting it. A stock earns the \'⭐ Quality\' tag if it meets these strict checks:\n\n• ROE > 15%: Superior management efficiency.\n• Net Profit Margin > 10%: Healthy business profitability.\n• Profit Growth (3Y) > 10%: Consistent bottom-line growth.\n• D/E Ratio &lt; 1.5: Safe levels of financial debt.</string><string name="edu_step2_title">2. Monitoring (The Traffic Lights)</string><string name="edu_step2_content">Move stocks into your Watchlist. The app monitors them 24/7:\n\n• AMBER (Potential): RSI &lt; 42. The stock is getting cheap or testing support.\n• GREEN (Buy): RSI &lt; 35 or confirmed momentum. Confirmed value + confirmed momentum.</string><string name="edu_step3_title">3. Execution (The Plan)</string><string formatted="false" name="edu_step3_content">When you see a Buy signal, use the \'Risk/Reward Calculator\'. Set a target (+10-20%) and a stop loss (-5%). Swing trades are held for a short period of 2–4 weeks. If the math doesn\'t show at least 2x reward for your risk, wait for a better price.</string><string name="edu_rsi_title">RSI (The Speedometer)</string><string name="edu_rsi_content">The Relative Strength Index (14 days). \n\n• Target 35 (Value): The stock is oversold. Prices are \'compressed\' and ready to bounce.\n• Target 65 (Caution): The stock is overbought. Risk of a pullback is high.</string><string name="edu_macd_title">MACD (The Momentum Switch)</string><string name="edu_macd_content">Think of this as the car\'s gears. Even if a stock is cheap (RSI 35), we look for the MACD Histogram to turn positive. This confirms that the momentum has shifted to the upside.</string><string name="edu_sma_title">SMA 50 &amp; 200 (Trend Guards)</string><string name="edu_sma_content">Moving Averages track the \'Average\' price over time.\n\n• SMA 200: The long-term \'Line in the Sand\'. Above this is a healthy Bull Market.\n• SMA 50: Mid-term health. Price above this suggests the trend is your friend.</string><string name="edu_bollinger_title">Bollinger Bands (Volatility Map)</string><string name="edu_bollinger_content">A \'Volatility Tube\' that wraps around price. \n\n• Lower Band (Value): Prices here are statistically cheap for their current movement.\n• Upper Band (Resistance): Prices here are stretched too far. High risk of a reversal.</string><string name="edu_golden_rule_title">The Golden Rule</string><string name="edu_golden_rule_content">SELL signals ALWAYS override BUY signals. If a stock has great momentum but hits RSI 65 or the Upper Bollinger Band, the app will warn you to wait. Never buy at the peak!</string><string name="about_idea_title">The Idea</string><string name="about_idea_content">TradingMate was born from the need for a disciplined, emotionless approach to stock trading. It aims to replace guesswork with data-driven signals.</string><string name="about_concept_title">The Concept</string><string name="about_concept_content">Our philosophy is \'Quality First\'. We focus on dividend stocks with solid fundamentals, monitored through indicators like RSI and MACD to find high-probability zones.</string><string name="about_ai_title">Built with AI</string><string name="about_ai_content">This application is built through human-AI collaboration. It was architected and implemented with the assistance of Google\'s Gemini AI.</string><string name="about_creator_title">The Creator</string><string name="about_creator_content">Developed by Thawee P., a software engineer and trading enthusiast passionate about building tools for financial empowerement.</string><string name="about_copyright">© 2024 TradingMate Project</string><string name="section_market_pulse">Market Pulse</string><string name="label_sentiment">Market Sentiment</string><string name="sentiment_bullish">BULLISH</string><string name="sentiment_bearish">BEARISH</string><string name="sentiment_balanced">BALANCED</string><string name="label_dividend_alerts">XD Alerts</string><string name="label_dividend_alert_window">XD Alert Window (Days)</string><string name="label_dividend_alert_end_year">Show until end of year</string><string name="label_no_upcoming_dividends">No upcoming dividends in the specified window.</string><string name="desc_max_risk_per_trade">The maximum percentage of your total account equity you are willing to lose on a single trade. If your stop loss is hit, you will lose exactly this amount.</string><string name="label_trailing_stop_percent">Trailing Stop Loss</string><string name="desc_trailing_stop_percent">The percentage drop from a stock\'s peak price that will trigger a stop loss alert.</string><string name="desc_max_open_exposure">The maximum combined risk across all your currently open trades. This protects your account from sudden, broad market crashes.</string><string name="desc_max_portfolio_allocation">The maximum percentage of your total account capital that can be invested in a single stock. Prevents you from putting all your eggs in one basket.</string><string name="desc_min_risk_reward">The minimum ratio between your potential profit (Reward) and potential loss (Risk) required to take a trade. A ratio of 2.0 means you expect to make twice as much as you risk losing.</string><string name="title_education_concept">TradingMate Concept: The 5 Layers</string><string formatted="false" name="edu_5_layers_intro">Our system evaluates a company\'s DNA through a strict 5-Layer filter. Swing Plays must pass (Qual OR Val) AND (Mom OR Sup). Dividend Stars must pass (Div AND Qual).</string><string name="edu_layer_1_title">Layer 1: QUAL (Quality/Fundamentals)</string><string formatted="false" name="edu_layer_1_content">The foundation. Does the company make money? We look for ROE > 15%, Net Profit Margin > 10%, consistent 3Y profit growth, and low debt (D/E &lt; 1.5).</string><string name="edu_layer_2_title">Layer 2: VAL (Valuation)</string><string formatted="false" name="edu_layer_2_content">Is the price fair? Even a great company is a bad investment if you pay too much. We look for underpriced or fair-value stocks using strict criteria: P/E Ratio between 0.1 and 15.0, and P/BV between 0.1 and 1.0.</string><string name="edu_layer_3_title">Layer 3: DIV (Dividend)</string><string formatted="false" name="edu_layer_3_content">For income investors. We accumulate and compound high-yield stocks (> 5%) indefinitely. Keep holding and reinvesting dividends unless fundamentals break (ROE &lt; 15% or high debt) or the dividend yield drops below 3%.</string><string name="edu_layer_4_title">Layer 4: MOM (Momentum)</string><string formatted="false" name="edu_layer_4_content">Are buyers stepping in? We detect early trend shifts and positive price momentum by checking if the MACD Histogram > 0.0. Never catch a falling knife.</string><string name="edu_layer_5_title">Layer 5: SUP (Support/Technicals)</string><string formatted="false" name="edu_layer_5_content">The trigger. We locate ideal entry zones or extreme discounts by finding when prices are \'oversold\' (RSI &lt; 35) or when our proprietary BUY/POTENTIAL zone signals flash.</string><string name="action_read_concept">Read Concept (The 5 Layers)</string><string name="about_tagline">Happy Trading! 🚀</string><string name="about_disclaimer_title">Disclaimer</string><string name="about_disclaimer_content">This application is designed for educational and informational purposes only. It does not constitute financial advice, investment recommendation, or a solicitation to buy or sell any securities. All trading and investment decisions are made at your own risk. The creators and developers of TradingMate are not responsible for any financial losses, damages, or consequences arising from the use of this application. Past performance does not guarantee future results. Always consult with a qualified financial advisor before making investment decisions.</string></file><file name="trading_mate_widget_info" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/xml/trading_mate_widget_info.xml" qualifiers="" type="xml"/><file name="inter_medium" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/font/inter_medium.ttf" qualifiers="" type="font"/><file name="inter_semibold" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/font/inter_semibold.ttf" qualifiers="" type="font"/><file name="inter_regular" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/font/inter_regular.ttf" qualifiers="" type="font"/><file name="inter_bold" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/font/inter_bold.ttf" qualifiers="" type="font"/><file name="ic_launcher" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/mipmap-anydpi-v26/ic_launcher.xml" qualifiers="anydpi-v26" type="mipmap"/><file name="ic_launcher_round" path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/main/res/mipmap-anydpi-v26/ic_launcher_round.xml" qualifiers="anydpi-v26" type="mipmap"/></source></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="debug$Generated" generated="true" ignore_pattern="!.svn:!.git:!.ds_store:!*.scc:.*:&lt;dir>_*:!CVS:!thumbs.db:!picasa.ini:!*~"><source path="/Users/thawee.p/Workspaces/github/tradingMate/app/src/debug/res"/></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="debug" gen